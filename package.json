{
  "name": "el-tarzy",
  "version": "2.0.0",
  "description": "EL-TARZY",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.10.1",
    "qrcode": "^1.5.4",
    "sweetalert2": "^11.26.25",
    "whatsapp-web.js": "^1.34.7"
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.9.1",
    "electron-rebuild": "^3.2.9"
  },
  "author": "Dev Blue Tech",
  "license": "MIT",
  "build": {
    "appId": "com.deltatech.eltarzy",
    "productName": "El-Tarzy",
    "win": {
      "target": [
        "nsis",
        "dir"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "برنامج الترزي"
    },
    "directories": {
      "output": "dist"
    }
  }
}
